{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "allowImportingTsExtensions": false,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@loykin/datasourcekit": ["packages/datasourcekit/dist/index.d.ts"],
      "@loykin/dashboardkit": ["src/index.ts"],
      "@loykin/dashboardkit/react": ["src/react.ts"],
      "@loykin/dashboardkit/url-state": ["src/adapters/url-state.ts"],
      "@loykin/dashboardkit/variables": ["src/variables-entrypoint.ts"],
      "@loykin/dashboardkit/addons": ["src/addons-entrypoint.ts"]
    }
  },
  "include": ["src"]
}
