{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@dashboard-engine/core": ["../src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
