{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "paths": {
      "@loykin/dashboardkit": ["../src/index.ts"],
      "@loykin/dashboardkit/react": ["../src/react.ts"],
      "@loykin/dashboardkit/url-state": ["../src/adapters/url-state.ts"],
      "@loykin/dashboardkit/addons": ["../src/addons-entrypoint.ts"]
    }
  },
  "include": ["src"]
}
