{
  "name": "@loykin/dashboardkit",
  "version": "0.0.0-dev",
  "description": "Headless dashboard orchestration engine — pure TypeScript, no React dependency",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./url-state": {
      "types": "./dist/url-state.d.ts",
      "import": "./dist/url-state.js",
      "require": "./dist/url-state.cjs"
    },
    "./variables": {
      "types": "./dist/variables.d.ts",
      "import": "./dist/variables.js",
      "require": "./dist/variables.cjs"
    },
    "./addons": {
      "types": "./dist/addons.d.ts",
      "import": "./dist/addons.js",
      "require": "./dist/addons.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit && eslint src --ext .ts,.tsx && tsup",
    "build:js": "tsup",
    "dev": "concurrently \"tsup --watch\" \"pnpm --filter playground dev\"",
    "test": "pnpm type-check && pnpm build && node --experimental-strip-types --test test/*.test.ts",
    "type-check": "tsc -p tsconfig.json && tsc -p playground/tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix"
  },
  "dependencies": {
    "zod": "^3.24.4",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-grid-layout": "^2.2.3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-grid-layout": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^2.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-grid-layout": "^2.2.3",
    "tsup": "^8.4.0",
    "@loykin/datasourcekit": "workspace:*",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2"
  },
  "keywords": [
    "dashboard",
    "dashboard-engine",
    "panel",
    "data-visualization",
    "headless",
    "react",
    "variables",
    "interpolation",
    "grafana-like",
    "grid-layout",
    "cross-filter",
    "streaming",
    "annotations",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/loykin/dashboardkit.git"
  },
  "homepage": "https://loykin.github.io/dashboardkit/playground",
  "bugs": {
    "url": "https://github.com/loykin/dashboardkit/issues"
  },
  "license": "MIT"
}
